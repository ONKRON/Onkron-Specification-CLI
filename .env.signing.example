host=...
user=...
database=...
password=...
# macOS code signing certificate (.p12 in base64 or file path)
CSC_LINK=
CSC_KEY_PASSWORD=

# macOS notarization (notarytool)
APPLE_ID=
APPLE_APP_SPECIFIC_PASSWORD=
APPLE_TEAM_ID=

# optional: explicit signing identity
# CSC_NAME=Developer ID Application: Your Name (TEAMID)

# Windows signing (optional for dist:win)
WIN_CSC_LINK=
WIN_CSC_KEY_PASSWORD=
